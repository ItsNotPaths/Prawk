+    size_t bot = vt->scroll_bot + 1;  /* exclusive */
+    if (r < vt->scroll_top) r = vt->scroll_top;
+    if (r >= bot) return;
+    if (n > bot - r - 1) n = bot - r - 1;
+    if (!n) return;
+
+    TMTLINE *buf[n];
+    memcpy(buf, vt->screen.lines + r, n * sizeof(TMTLINE *));
+    memmove(vt->screen.lines + r, vt->screen.lines + r + n,
+            (bot - n - r) * sizeof(TMTLINE *));
+    memcpy(vt->screen.lines + (bot - n), buf, n * sizeof(TMTLINE *));
