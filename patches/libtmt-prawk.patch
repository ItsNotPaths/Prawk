+/* prawk: DECSTBM (\e[<top>;<bot>r). Clamps to screen, validates top<bot,
+ * and (per VT spec) homes the cursor to top of region. */
+HANDLER(decstbm)
+    size_t top = vt->pars[0] > 0 ? vt->pars[0] - 1 : 0;
+    size_t bot = (vt->npar > 1 && vt->pars[1] > 0)
+                  ? vt->pars[1] - 1 : s->nline - 1;
+    if (top >= s->nline) top = s->nline - 1;
+    if (bot >= s->nline) bot = s->nline - 1;
+    if (top >= bot) { top = 0; bot = s->nline - 1; }
+    vt->scroll_top = top;
+    vt->scroll_bot = bot;
+    c->r = top;
+    c->c = 0;
 }
 
